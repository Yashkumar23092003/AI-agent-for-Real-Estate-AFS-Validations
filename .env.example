# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── SMTP (Gmail app password recommended) ────────────────────────────────────
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here

# ── Google Sheets — AFS ↔ Sheet Audit ────────────────────────────────────────
# Path to the Google service account JSON key file.
# Share your Google Sheet with the service account's client_email before running.
GOOGLE_SHEETS_CREDENTIALS_PATH=AI-Agent-for-AFS-Verification/AFS_Verification_GS.json
# Optional: pre-fill the Sheet ID in the UI (users can still override it)
DEFAULT_SHEET_ID=1pdRt04-OgUvEQJLXqZXBtZJO2Cs7Yg4KwfmW7k7heYg

# ── Log sheet — append-only audit trail (single source of truth) ──────────────
# A separate Google Sheet that every verification appends a row to.
# Share it with the service account's client_email as EDITOR.
# Tabs "KYC_Log" and "AFS_Log" are created automatically on first write.
LOG_SHEET_ID=your_log_sheet_id_here

# For Streamlit Cloud (no file on disk): paste the entire service-account JSON
# as a single-line string here instead of using GOOGLE_SHEETS_CREDENTIALS_PATH.
# GOOGLE_SHEETS_CREDENTIALS_JSON={"type":"service_account",...}
